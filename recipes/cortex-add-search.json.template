    "defaults": {
      "model": "claude-sonnet-4-20250514",
      "on_failure": "stop"
    },
    "stages": [
      {
        "id": "profile-source",
        "name": "Profile source corpus",
        "persona": "$da",
        "status": "pending",
        "prompt": ".cocoplus/prompts/profile-source-prompt.md",
        "checkpoints": [".cocoplus/lifecycle/search/source-profile.md"],
        "deliverables": [{ "files": [".cocoplus/lifecycle/search/source-profile.md"] }],
        "validation_commands": ["test -f .cocoplus/lifecycle/search/source-profile.md"],
        "hitl": false,
        "maxConsecutiveFailures": 3
      },
      {
        "id": "design-search",
        "name": "Design service contract",
        "persona": "$de",
        "status": "pending",
        "dependencies": ["profile-source"],
        "prompt": ".cocoplus/prompts/design-search-prompt.md",
        "checkpoints": [".cocoplus/lifecycle/search/design.md"],
        "deliverables": [{ "files": [".cocoplus/lifecycle/search/design.md"] }],
        "validation_commands": ["grep -E \"service|warehouse|search column\" .cocoplus/lifecycle/search/design.md"],
        "hitl": true,
        "maxConsecutiveFailures": 3
      },
      {
        "id": "create-service",
        "name": "Create Cortex Search SQL",
        "persona": "$de",
        "status": "pending",
        "dependencies": ["design-search"],
        "prompt": ".cocoplus/prompts/create-service-prompt.md",
        "checkpoints": [".cocoplus/lifecycle/search/create-service.sql"],
        "deliverables": [{ "files": [".cocoplus/lifecycle/search/create-service.sql"] }],
        "validation_commands": ["grep -i \"CREATE.*CORTEX SEARCH\" .cocoplus/lifecycle/search/create-service.sql"],
        "hitl": false,
        "maxConsecutiveFailures": 3
      },
      {
        "id": "quality-check",
        "name": "Validate retrieval quality",
        "persona": "$ae",
        "status": "pending",
        "dependencies": ["create-service"],
        "prompt": ".cocoplus/prompts/quality-check-prompt.md",
        "checkpoints": [".cocoplus/lifecycle/search/retrieval-quality.md"],
        "deliverables": [{ "files": [".cocoplus/lifecycle/search/retrieval-quality.md"] }],
        "validation_commands": ["test -f .cocoplus/lifecycle/search/retrieval-quality.md"],
        "hitl": true,
        "maxConsecutiveFailures": 3
      },
      {
        "id": "usage-guidance",
        "name": "Document usage guidance",
        "persona": "$bi",
        "status": "pending",
        "dependencies": ["quality-check"],
        "prompt": ".cocoplus/prompts/usage-guidance-prompt.md",
        "checkpoints": [".cocoplus/lifecycle/search/usage-guidance.md"],
        "deliverables": [{ "files": [".cocoplus/lifecycle/search/usage-guidance.md"] }],
        "validation_commands": ["test -f .cocoplus/lifecycle/search/usage-guidance.md"],
        "hitl": false,
        "maxConsecutiveFailures": 3
      }
    ]
  }
