{
  "name": "cortex-add-search",
  "description": "Configure, validate, and document a Cortex Search service.",
  "parameters": {
    "source_table": { "required": true, "description": "Fully qualified source table." },
    "search_column": { "required": true, "description": "Text column indexed by Cortex Search." },
    "warehouse": { "required": true, "description": "Warehouse used to maintain the service." },
    "service_name": { "required": true, "description": "Cortex Search service name." }
  },
  "flow": {
    "meta": {
      "name": "Add Cortex Search",
      "phase": "plan",
      "generated_by": "cocorecipe",
