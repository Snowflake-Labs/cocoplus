<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CocoMeter — Usage Dashboard</title>
  <style>
    :root {
      --bg:       #0d1117;
      --surface:  #161b22;
      --surface2: #1e2530;
      --surface3: #252d3a;
      --border:   #2a3245;
      --text:     #e2e8f0;
      --muted:    #7d8fa8;
      --accent:   #7c3aed;
      --success:  #22c55e;
      --blue:     #3b82f6;
      --amber:    #f59e0b;
      --red:      #ef4444;
      --cyan:     #06b6d4;

      --haiku-color:  #06b6d4;
      --sonnet-color: #7c3aed;
      --opus-color:   #f59e0b;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 13px;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Toolbar ─────────────────────────────────────── */
    .toolbar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      flex-wrap: wrap;
    }
    .logo { font-size: 13px; font-weight: 700; color: var(--accent); white-space: nowrap; }
    .project-name { font-size: 13px; font-weight: 500; color: var(--text); white-space: nowrap; }
    .sep { width: 1px; height: 20px; background: var(--border); flex-shrink: 0; }
    .gen-time { font-size: 11px; color: var(--muted); white-space: nowrap; }

    .btn {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 4px 11px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
      transition: background 0.12s;
      user-select: none;
    }
    .btn:hover { background: var(--surface3); }
    .btn.primary { background: var(--accent); border-color: var(--accent); }
    .btn.primary:hover { background: #6d28d9; }

    .filter-row { display: flex; align-items: center; gap: 8px; margin-left: auto; }
    .filter-label { font-size: 11px; color: var(--muted); }
    select {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 4px 8px;
      border-radius: 6px;
      font-size: 12px;
      outline: none;
      cursor: pointer;
    }

    /* ── Main layout ─────────────────────────────────── */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0;
      overflow: auto;
    }

    .section {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
    }

    .section-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
    }

    /* ── Summary Cards ───────────────────────────────── */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 10px;
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 14px 16px;
    }
    .card-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .card-value {
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
      margin-bottom: 4px;
    }
    .card-sub { font-size: 11px; color: var(--muted); }
    .card-accent { border-top: 2px solid; }
    .card-accent-purple { border-top-color: var(--accent); }
    .card-accent-blue   { border-top-color: var(--blue); }
    .card-accent-amber  { border-top-color: var(--amber); }
    .card-accent-cyan   { border-top-color: var(--cyan); }

    /* ── Two-col layout ──────────────────────────────── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 0;
      border-bottom: 1px solid var(--border);
    }
    .two-col .pane {
      padding: 16px 20px;
    }
    .two-col .pane:first-child {
      border-right: 1px solid var(--border);
    }

    /* ── Tables ──────────────────────────────────────── */
    .table-wrap { overflow-x: auto; }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    th {
      text-align: left;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 6px 10px;
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
    }
    th:hover { color: var(--text); }
    th.sorted { color: var(--accent); }
    td {
      padding: 8px 10px;
      border-bottom: 1px solid #1e2530;
      vertical-align: middle;
    }
    tr:hover td { background: var(--surface2); }
    tr.selected td { background: rgba(124,58,237,0.08); }
    tr.selected td:first-child { border-left: 2px solid var(--accent); }

    .mono { font-family: 'Courier New', Courier, monospace; font-size: 10.5px; color: var(--muted); }
    .truncate { max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* Token bar inside table cell */
    .tok-bar-wrap { display: flex; align-items: center; gap: 6px; min-width: 120px; }
    .tok-bar {
      flex: 1;
      height: 6px;
      background: var(--border);
      border-radius: 3px;
      overflow: hidden;
    }
    .tok-bar-fill {
      height: 100%;
      border-radius: 3px;
      background: var(--accent);
      transition: width 0.3s;
    }
    .tok-val { font-size: 11px; color: var(--text); min-width: 54px; text-align: right; }

    /* Badge */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      font-size: 10px;
      font-weight: 600;
      padding: 2px 6px;
      border-radius: 4px;
      white-space: nowrap;
    }
    .badge-spec     { background: rgba(124,58,237,0.12); color: #c4b5fd; }
    .badge-plan     { background: rgba(59,130,246,0.12);  color: #93c5fd; }
    .badge-build    { background: rgba(34,197,94,0.12);   color: #86efac; }
    .badge-test     { background: rgba(245,158,11,0.12);  color: #fcd34d; }
    .badge-review   { background: rgba(239,68,68,0.12);   color: #fca5a5; }
    .badge-ship     { background: rgba(6,182,212,0.12);   color: #67e8f9; }
    .badge-default  { background: rgba(100,116,139,0.12); color: #94a3b8; }

    /* ── Model distribution ──────────────────────────── */
    .model-list { display: flex; flex-direction: column; gap: 14px; }
    .model-item { display: flex; flex-direction: column; gap: 5px; }
    .model-header { display: flex; align-items: center; justify-content: space-between; }
    .model-name { font-size: 12px; font-weight: 600; }
    .model-meta { font-size: 10px; color: var(--muted); }
    .model-bar-track {
      height: 8px;
      background: var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .model-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.4s;
    }
    .model-sub {
      display: flex;
      gap: 12px;
      font-size: 10px;
      color: var(--muted);
      flex-wrap: wrap;
    }
    .model-sub span { display: flex; align-items: center; gap: 3px; }
    .dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }

    /* Cache efficiency bar */
    .cache-section { margin-top: 20px; }
    .cache-bar-wrap { position: relative; height: 18px; border-radius: 4px; overflow: hidden; background: var(--border); display: flex; }
    .cache-seg { height: 100%; transition: width 0.4s; display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 700; overflow: hidden; }

    /* ── Request detail panel ────────────────────────── */
    .req-filters {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }
    .req-filter-chip {
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 12px;
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted);
      cursor: pointer;
      transition: all 0.12s;
      user-select: none;
    }
    .req-filter-chip.active {
      background: var(--accent-dim, rgba(124,58,237,0.2));
      border-color: var(--accent);
      color: var(--text);
    }

    .empty-state {
      text-align: center;
      padding: 32px;
      color: var(--muted);
      font-size: 12px;
    }

    /* ── Parent-child link ───────────────────────────── */
    .parent-chip {
      font-size: 9px;
      background: var(--surface3);
      border: 1px solid var(--border);
      border-radius: 3px;
      padding: 1px 5px;
      color: var(--muted);
      white-space: nowrap;
    }

    /* ── Modal ───────────────────────────────────────── */
    .overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.65);
      z-index: 200;
      display: none;
      align-items: center;
      justify-content: center;
    }
    .overlay.open { display: flex; }
    .modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      width: 660px;
      max-width: 94vw;
      max-height: 82vh;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .modal h3 { font-size: 15px; font-weight: 600; }
    .modal p  { font-size: 11px; color: var(--muted); }
    .modal textarea {
      flex: 1;
      min-height: 260px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-family: 'Courier New', Courier, monospace;
      font-size: 11.5px;
      padding: 12px;
      resize: vertical;
      outline: none;
    }
    .modal textarea:focus { border-color: var(--accent); }
    .modal-foot { display: flex; align-items: center; gap: 8px; }
    .modal-err { font-size: 11px; color: var(--red); flex: 1; }
    .modal-actions { display: flex; gap: 8px; }

    /* Snowflake note banner */
    .sf-banner {
      background: rgba(6,182,212,0.07);
      border: 1px solid rgba(6,182,212,0.25);
      border-radius: 6px;
      padding: 8px 12px;
      font-size: 11px;
      color: #67e8f9;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .sf-banner .sf-dot { width: 6px; height: 6px; border-radius: 50%; background: #06b6d4; flex-shrink: 0; }
  </style>
</head>
<body>

<!-- ── Toolbar ─────────────────────────────────────────── -->
<div class="toolbar">
  <span class="logo">◈ CocoMeter</span>
  <div class="sep"></div>
  <span class="project-name" id="proj-name">Usage Dashboard</span>
  <div class="sep"></div>
  <span class="gen-time" id="gen-time"></span>

  <div class="filter-row">
    <span class="filter-label">Session:</span>
    <select id="session-filter"><option value="all">All Sessions</option></select>
    <span class="filter-label">Phase:</span>
    <select id="phase-filter">
      <option value="all">All Phases</option>
      <option value="spec">Spec</option>
      <option value="plan">Plan</option>
      <option value="build">Build</option>
      <option value="test">Test</option>
      <option value="review">Review</option>
      <option value="ship">Ship</option>
    </select>
    <button class="btn primary" id="btn-load">⬆ Load JSON</button>
    <button class="btn" id="btn-reset">↺ Reset</button>
  </div>
</div>

<!-- ── Main ───────────────────────────────────────────── -->
<div class="main" id="main">

  <!-- Summary Cards -->
  <div class="section" id="section-summary">
    <div class="section-title">Summary</div>
    <div class="cards" id="summary-cards"></div>
  </div>

  <!-- Snowflake source banner -->
  <div class="section" id="section-banner" style="padding-top:10px;padding-bottom:10px;">
    <div class="sf-banner">
      <div class="sf-dot"></div>
      <span id="sf-banner-text">Data sourced from <strong>SNOWFLAKE.ACCOUNT_USAGE.CORTEX_CODE_CLI_USAGE_HISTORY</strong> — correlated by REQUEST_ID and PARENT_REQUEST_ID.</span>
    </div>
  </div>

  <!-- Stage + Model split -->
  <div class="two-col" id="two-col">
    <!-- Stage Attribution -->
    <div class="pane" id="pane-stages">
      <div class="section-title">Stage Attribution</div>
      <div class="table-wrap">
        <table id="stage-table">
          <thead>
            <tr>
              <th data-col="label">Stage</th>
              <th data-col="phase">Phase</th>
              <th data-col="tokens_total" class="sorted">Tokens</th>
              <th data-col="credits">Credits</th>
              <th data-col="cache_pct">Cache %</th>
              <th data-col="request_count">Requests</th>
            </tr>
          </thead>
          <tbody id="stage-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Model Distribution -->
    <div class="pane" id="pane-models">
      <div class="section-title">Model Distribution</div>
      <div class="model-list" id="model-list"></div>
      <div class="cache-section">
        <div class="section-title" style="margin-top:0;margin-bottom:8px;">Token Composition</div>
        <div class="cache-bar-wrap" id="cache-bar"></div>
        <div class="model-sub" style="margin-top:6px;" id="cache-legend"></div>
      </div>
    </div>
  </div>

  <!-- Request Log -->
  <div class="section" id="section-requests">
    <div class="section-title">Request Log
      <span id="req-count" style="font-weight:400;text-transform:none;font-size:11px;color:var(--muted);margin-left:6px;"></span>
    </div>
    <div class="req-filters" id="stage-chips"></div>
    <div class="table-wrap">
      <table id="req-table">
        <thead>
          <tr>
            <th>REQUEST_ID</th>
            <th>PARENT</th>
            <th>Stage</th>
            <th>Time</th>
            <th data-col="tokens_total">Tokens ↓</th>
            <th>Input</th>
            <th>Cache Read</th>
            <th>Cache Write</th>
            <th>Output</th>
            <th>Credits</th>
            <th>Model</th>
          </tr>
        </thead>
        <tbody id="req-tbody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- ── JSON Modal ─────────────────────────────────────── -->
<div class="overlay" id="overlay">
  <div class="modal">
    <h3>Load Meter JSON</h3>
    <p>Paste CocoMeter usage data (generated by <code>/meter view</code>) and click Apply.</p>
    <textarea id="json-ta" spellcheck="false"></textarea>
    <div class="modal-foot">
      <span class="modal-err" id="json-err"></span>
      <div class="modal-actions">
        <button class="btn" id="btn-cancel">Cancel</button>
        <button class="btn primary" id="btn-apply">Apply</button>
      </div>
    </div>
  </div>
</div>

<script>
