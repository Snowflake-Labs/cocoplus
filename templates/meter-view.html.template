    { request_id:"req-b2e7a4-0002", parent_request_id:"req-b2e7a4-0001", stage_id:"B004",   usage_time:"2025-04-17T10:02:38Z", tokens:{ input:11150, cache_read_input:4550, cache_write_input:700, output:2600 }, credits:0.32, model:"claude-3-5-sonnet-20241022" },
    { request_id:"req-c4f1d9-0001", parent_request_id:null,              stage_id:"review", usage_time:"2025-04-20T14:18:55Z", tokens:{ input:6900, cache_read_input:3100, cache_write_input:450, output:1600 }, credits:0.27, model:"claude-3-opus-20240229" },
    { request_id:"req-c4f1d9-0002", parent_request_id:"req-c4f1d9-0001", stage_id:"review", usage_time:"2025-04-20T14:35:20Z", tokens:{ input:6900, cache_read_input:3100, cache_write_input:450, output:1600 }, credits:0.27, model:"claude-3-opus-20240229" }
  ],
  model_totals: {
    "claude-3-opus-20240229":      { tokens:65300,  credits:1.20 },
    "claude-3-5-sonnet-20241022":  { tokens:213629, credits:3.42 },
    "claude-3-haiku-20240307":     { tokens:5800,   credits:0.11 }
  }
};

// ════════════════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════════════════
let data = INJECTED_METER_DATA || SAMPLE;
let activeStageFilter = 'all';
let activePhaseFilter = 'all';
let activeSessionFilter = 'all';

// ════════════════════════════════════════════════════════════
// UTILITIES
// ════════════════════════════════════════════════════════════
function fmt(n, digits = 0) {
  if (n === null || n === undefined) return '—';
  if (n >= 1000000) return (n/1000000).toFixed(1) + 'M';
  if (n >= 1000)    return (n/1000).toFixed(digits === 0 ? 1 : digits) + 'k';
  return n.toLocaleString();
}
function fmtCredits(n) {
  if (n === null || n === undefined) return '—';
  return n < 0.01 ? '<0.01' : n.toFixed(3);
}
function fmtTime(iso) {
  if (!iso) return '—';
  try { return new Date(iso).toLocaleString(undefined, { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }); }
  catch { return iso; }
}
function esc(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function stageTotalTokens(s) {
  return (s.tokens.input||0) + (s.tokens.cache_read||0) + (s.tokens.cache_write||0) + (s.tokens.output||0);
}
function reqTotalTokens(r) {
  return (r.tokens.input||0) + (r.tokens.cache_read_input||0) + (r.tokens.cache_write_input||0) + (r.tokens.output||0);
}
function stageCachePct(s) {
  const total = stageTotalTokens(s);
  if (!total) return 0;
  return Math.round(((s.tokens.cache_read||0) / total) * 100);
}

function phaseBadge(phase) {
  const cls = { spec:'badge-spec', plan:'badge-plan', build:'badge-build', test:'badge-test', review:'badge-review', ship:'badge-ship' }[phase] || 'badge-default';
  return `<span class="badge ${cls}">${esc(phase || '—')}</span>`;
}

const MODEL_COLORS = {
  'claude-3-opus-20240229':     '#f59e0b',
  'claude-3-5-sonnet-20241022': '#7c3aed',
  'claude-3-haiku-20240307':    '#06b6d4',
  'claude-3-sonnet-20240229':   '#3b82f6',
};
function modelColor(name) {
  return MODEL_COLORS[name] || '#64748b';
}
function modelShort(name) {
  if (!name) return '—';
  if (name.includes('haiku'))  return 'Haiku';
  if (name.includes('sonnet')) return 'Sonnet';
  if (name.includes('opus'))   return 'Opus';
  return name.split('-').pop();
}

// ════════════════════════════════════════════════════════════
// RENDER
// ════════════════════════════════════════════════════════════
function render(d) {
  data = d;
  document.getElementById('proj-name').textContent = d.project || 'CocoMeter';
  if (d.generated_at) {
    document.getElementById('gen-time').textContent =
      'Generated ' + fmtTime(d.generated_at) +
      (d.snowflake_query_at ? ' · Snowflake synced ' + fmtTime(d.snowflake_query_at) : '');
  }

  renderSummary(d);
  renderStages(d);
  renderModels(d);
  renderRequests(d);
  buildSessionFilter(d);
  buildStageChips(d);
}

// ── Summary cards
function renderSummary(d) {
  const s = d.summary || {};
  const cacheTotal = (s.cache_read_tokens||0);
  const inputTotal = (s.input_fresh_tokens||0) + (s.cache_read_tokens||0) + (s.cache_write_tokens||0);
  const cacheRate  = inputTotal ? Math.round((cacheTotal / inputTotal) * 100) : 0;

  const cards = [
    { label:'Total Tokens', value: fmt(s.total_tokens), sub: `${d.date_range?.from || ''} → ${d.date_range?.to || ''}`, accent:'card-accent-purple' },
    { label:'Total Credits', value: fmtCredits(s.total_credits), sub: `${s.total_requests||0} requests · ${s.total_sessions||0} sessions`, accent:'card-accent-blue' },
    { label:'Cache Efficiency', value: cacheRate + '%', sub: `${fmt(s.cache_read_tokens)} tokens served from cache`, accent:'card-accent-cyan' },
    { label:'Output Tokens', value: fmt(s.output_tokens), sub: `of ${fmt(s.total_tokens)} total`, accent:'card-accent-amber' },
  ];

  document.getElementById('summary-cards').innerHTML = cards.map(c => `
    <div class="card card-accent ${c.accent}">
      <div class="card-label">${c.label}</div>
      <div class="card-value">${c.value}</div>
      <div class="card-sub">${c.sub}</div>
    </div>
  `).join('');
}

// ── Stage attribution table
function renderStages(d) {
  const stages = filterStages(d);
  const maxTok = Math.max(...stages.map(stageTotalTokens), 1);

  document.getElementById('stage-tbody').innerHTML = stages.length ? stages.map(s => {
    const total = stageTotalTokens(s);
    const barPct = Math.round((total / maxTok) * 100);
    const cachePct = stageCachePct(s);
    const modelNames = Object.keys(s.models || {});
    const modelDots = modelNames.map(m =>
      `<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${modelColor(m)};margin-right:2px;" title="${m}"></span>`
    ).join('');

    return `<tr data-sid="${esc(s.stage_id)}" class="stage-row" style="cursor:pointer" onclick="filterToStage('${esc(s.stage_id)}')">
      <td>
        <div style="font-weight:600;margin-bottom:2px;">${esc(s.label)}</div>
        <div style="font-size:10px;color:var(--muted);">${esc(s.agent||'')}</div>
      </td>
      <td>${phaseBadge(s.phase)}</td>
      <td>
        <div class="tok-bar-wrap">
          <div class="tok-bar"><div class="tok-bar-fill" style="width:${barPct}%"></div></div>
          <div class="tok-val">${fmt(total)}</div>
        </div>
      </td>
      <td>${fmtCredits(s.credits)}</td>
      <td><span style="color:${cachePct>30?'var(--cyan)':'var(--muted)'}">${cachePct}%</span></td>
      <td style="color:var(--muted)">${s.request_count}</td>
    </tr>`;
  }).join('') : '<tr><td colspan="6" class="empty-state">No stages match current filters.</td></tr>';
}

// ── Model distribution
function renderModels(d) {
  const totals = d.model_totals || {};
  const allTokens = Object.values(totals).reduce((s, m) => s + (m.tokens||0), 0) || 1;
  const sorted = Object.entries(totals).sort((a,b) => b[1].tokens - a[1].tokens);

  document.getElementById('model-list').innerHTML = sorted.map(([name, m]) => {
    const pct = Math.round(((m.tokens||0) / allTokens) * 100);
    const color = modelColor(name);
    return `<div class="model-item">
      <div class="model-header">
        <div class="model-name" style="color:${color}">${modelShort(name)}</div>
        <div class="model-meta">${fmt(m.tokens)} tokens · ${fmtCredits(m.credits)} credits</div>
      </div>
      <div class="model-bar-track">
        <div class="model-bar-fill" style="width:${pct}%;background:${color}"></div>
      </div>
      <div class="model-sub"><span>${pct}% of total</span></div>
    </div>`;
  }).join('');

  // Token composition bar
  const s = d.summary || {};
  const total = (s.input_fresh_tokens||0) + (s.cache_read_tokens||0) + (s.cache_write_tokens||0) + (s.output_tokens||0) || 1;
  const segs = [
    { key:'cache_read_tokens',  label:'Cache Read',  color:'#06b6d4' },
    { key:'cache_write_tokens', label:'Cache Write', color:'#0891b2' },
    { key:'input_fresh_tokens', label:'Fresh Input', color:'#7c3aed' },
    { key:'output_tokens',      label:'Output',      color:'#22c55e' },
  ];
  document.getElementById('cache-bar').innerHTML = segs.map(sg => {
    const v = s[sg.key] || 0;
    const pct = Math.max(Math.round((v/total)*100), 0);
    return `<div class="cache-seg" style="width:${pct}%;background:${sg.color}" title="${sg.label}: ${fmt(v)}"></div>`;
  }).join('');
  document.getElementById('cache-legend').innerHTML = segs.map(sg =>
    `<span><span class="dot" style="background:${sg.color}"></span>${sg.label}</span>`
  ).join('');
}

// ── Request log
function renderRequests(d) {
  const reqs = filterRequests(d);
  document.getElementById('req-count').textContent = `(${reqs.length} of ${(d.requests||[]).length})`;

  document.getElementById('req-tbody').innerHTML = reqs.length ? reqs.map(r => {
    const stageLabel = (d.stages||[]).find(s=>s.stage_id===r.stage_id)?.label || r.stage_id || '—';
    const stagePhase = (d.stages||[]).find(s=>s.stage_id===r.stage_id)?.phase || '';
    const total = reqTotalTokens(r);
    const shortId = r.request_id?.slice(-12) || '—';
    const shortParent = r.parent_request_id ? r.parent_request_id.slice(-12) : null;

    return `<tr>
      <td class="mono truncate" title="${esc(r.request_id)}">${esc(shortId)}</td>
      <td>${shortParent ? `<span class="parent-chip" title="${esc(r.parent_request_id)}">↑ ${esc(shortParent)}</span>` : '<span style="color:var(--muted);font-size:10px;">root</span>'}</td>
      <td>
        <div style="font-size:11px;font-weight:500;">${esc(stageLabel)}</div>
        ${stagePhase ? phaseBadge(stagePhase) : ''}
      </td>
      <td style="color:var(--muted);font-size:11px;white-space:nowrap">${fmtTime(r.usage_time)}</td>
      <td style="font-weight:600">${fmt(total)}</td>
      <td style="color:var(--muted)">${fmt(r.tokens?.input||0)}</td>
      <td style="color:var(--cyan)">${fmt(r.tokens?.cache_read_input||0)}</td>
      <td style="color:#0891b2">${fmt(r.tokens?.cache_write_input||0)}</td>
      <td style="color:var(--success)">${fmt(r.tokens?.output||0)}</td>
      <td>${fmtCredits(r.credits)}</td>
      <td><span class="badge" style="background:${modelColor(r.model)}22;color:${modelColor(r.model)}">${esc(modelShort(r.model))}</span></td>
    </tr>`;
  }).join('') : '<tr><td colspan="11" class="empty-state">No requests match current filters.</td></tr>';
}

// ── Filtering helpers
function filterStages(d) {
  return (d.stages||[]).filter(s => {
    if (activePhaseFilter !== 'all' && s.phase !== activePhaseFilter) return false;
    return true;
  });
}

function filterRequests(d) {
  return (d.requests||[]).filter(r => {
    if (activeStageFilter !== 'all' && r.stage_id !== activeStageFilter) return false;
    if (activePhaseFilter !== 'all') {
      const stage = (d.stages||[]).find(s => s.stage_id === r.stage_id);
      if (stage && stage.phase !== activePhaseFilter) return false;
    }
    return true;
  });
}

function buildSessionFilter(d) {
  // Infer sessions if available
  const sel = document.getElementById('session-filter');
  sel.innerHTML = '<option value="all">All Sessions</option>';
}

function buildStageChips(d) {
  const container = document.getElementById('stage-chips');
  const stages = d.stages || [];
  container.innerHTML = [
    `<span class="req-filter-chip active" data-sid="all" onclick="filterToStage('all')">All Stages</span>`,
    ...stages.map(s =>
      `<span class="req-filter-chip" data-sid="${esc(s.stage_id)}" onclick="filterToStage('${esc(s.stage_id)}')">${esc(s.label)}</span>`
    )
  ].join('');
}

function filterToStage(sid) {
  activeStageFilter = sid;
  document.querySelectorAll('.req-filter-chip').forEach(el => {
    el.classList.toggle('active', el.dataset.sid === sid);
  });
  document.querySelectorAll('.stage-row').forEach(el => {
    el.classList.toggle('selected', sid !== 'all' && el.dataset.sid === sid);
  });
  renderRequests(data);
}

// ── Toolbar events
document.getElementById('phase-filter').addEventListener('change', e => {
  activePhaseFilter = e.target.value;
  renderStages(data);
  renderRequests(data);
});

document.getElementById('session-filter').addEventListener('change', e => {
  activeSessionFilter = e.target.value;
  renderRequests(data);
});

// ── JSON Modal
document.getElementById('btn-load').addEventListener('click', () => {
  document.getElementById('json-ta').value = JSON.stringify(data, null, 2);
  document.getElementById('json-err').textContent = '';
  document.getElementById('overlay').classList.add('open');
});
document.getElementById('btn-cancel').addEventListener('click', () =>
  document.getElementById('overlay').classList.remove('open')
);
document.getElementById('btn-apply').addEventListener('click', () => {
  try {
    const parsed = JSON.parse(document.getElementById('json-ta').value);
    if (!parsed.summary) throw new Error('Missing "summary" object');
    activeStageFilter = 'all'; activePhaseFilter = 'all';
    render(parsed);
    document.getElementById('overlay').classList.remove('open');
  } catch(e) {
    document.getElementById('json-err').textContent = '⚠ ' + e.message;
  }
});
document.getElementById('overlay').addEventListener('click', e => {
  if (e.target === e.currentTarget) document.getElementById('overlay').classList.remove('open');
});

document.getElementById('btn-reset').addEventListener('click', () => {
  activeStageFilter = 'all'; activePhaseFilter = 'all'; activeSessionFilter = 'all';
  document.getElementById('phase-filter').value = 'all';
  render(INJECTED_METER_DATA || SAMPLE);
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.getElementById('overlay').classList.remove('open');
});

// ════════════════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════════════════
render(INJECTED_METER_DATA || SAMPLE);
</script>
</body>
</html>
